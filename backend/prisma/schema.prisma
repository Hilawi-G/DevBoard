datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. The User Table
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  
  // A user can have many tasks (One-to-Many Relationship)
  tasks     Task[]
}

// 2. The Task Table
model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("TODO") // Can be: TODO, IN_PROGRESS, DONE
  createdAt   DateTime @default(now())
  
  // This links each task directly back to a specific User
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}